version = 1
# Intentional low-power default. This is animation cadence, not monitor refresh.
fps = 15

[renderer]
# 1.0 = native resolution. Lower values render smaller, then upscale.
scale = 1.0
# "nearest" looks crisper/blockier; "linear" looks smoother/softer.
upscale_filter = "nearest"

[effect]
# Active wallpaper effect. All GPU effects require EGL; they fall back to
# colormix automatically if GPU is unavailable.
name = "colormix"
# name = "glass_drift"
# name = "aurora_bands"
# name = "cloud_chamber"
# name = "ribbon_orbit"
# name = "plasma_quilt"
# name = "liquid_marble"
# name = "velvet_mesh"
# name = "soft_interference"
# name = "starfield_fog"
# name = "tube_lights"

[effect.settings]
# Animation speed multiplier. Range: 0.25–2.5. Default: 1.0.
# Applies to all effects. Out-of-range values are rejected at startup.
speed = 1.0
palette = ["#1e1e2e", "#89b4fa", "#a6e3a1"]
